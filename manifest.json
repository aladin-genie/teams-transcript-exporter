{
  "manifest_version": 3,
  "name": "Teams Transcript Exporter",
  "version": "1.0.0",
  "description": "Export Microsoft Teams meeting transcripts to JSON. Works on SharePoint meeting recordings.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://teams.microsoft.com/*",
    "https://*.sharepoint.com/*",
    "https://*.office.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://*.sharepoint.com/*",
        "https://*.office.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
